# Environment
COMPOSE_PROJECT_NAME=legal-doc-intel

# Ports
FRONTEND_PORT=3000
GO_API_PORT=8080
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
PY_AI_API_PORT=8000
POSTGRES_PORT=5432
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
REDIS_PORT=6379
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION_NAME=document_chunks
QDRANT_VECTOR_SIZE=1536
QDRANT_DISTANCE=cosine
QDRANT_STARTUP_CHECK_ENABLED=true

# Postgres
POSTGRES_DB=legal_doc_intel
POSTGRES_USER=app
POSTGRES_PASSWORD=app
DATABASE_URL=postgresql://app:app@postgres:5432/legal_doc_intel?sslmode=disable
DATABASE_PING_TIMEOUT=5s

# Service-to-service auth (placeholder)
INTERNAL_SERVICE_TOKEN=local-dev-token
INTERNAL_AI_BASE_URL=http://py-ai-api:8000
INTERNAL_AI_TIMEOUT=5m
EXTERNAL_COPY_API_BASE_URL=
EXTERNAL_COPY_API_TOKEN=
EXTERNAL_COPY_API_TIMEOUT=8s
EXTERNAL_COPY_API_RETRIES=3

# Storage
STORAGE_PROVIDER=minio
LOCAL_STORAGE_PATH=/samples/storage
AZURE_STORAGE_ACCOUNT=
AZURE_BLOB_CONTAINER=
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=contracts
MINIO_USE_SSL=false
